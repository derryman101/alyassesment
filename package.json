{
  "name": "nodeapp-cicd-demo",
  "version": "1.0.0",
  "description": "CI/CD Demo app for DevOps assessment",
  "main": "app/index.js",
  "scripts": {
    "start": "node app/index.js",
    "dev": "nodemon app/index.js",
    "test": "jest --coverage --forceExit",
    "test:ci": "jest --coverage --forceExit --ci"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["app/**/*.js"]
  }
}
